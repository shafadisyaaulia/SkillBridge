# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ==============================================================================
# Dependencies (frontend / Node.js)
# ==============================================================================
/node_modules
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ==============================================================================
# Next.js / build output
# ==============================================================================
/.next/
/out/
/build
/coverage
*.tsbuildinfo
next-env.d.ts

# ==============================================================================
# Python (backend)
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Virtual environments (jangan pernah push folder env)
venv/
.venv/
env/
ENV/

# ==============================================================================
# Environment variables
# Jangan push file berisi konfigurasi/secret lokal — TAPI tetap sertakan
# file *.example sebagai template aman untuk tim.
# ==============================================================================
.env
.env.*
!.env.example
!backend/.env.example

# ==============================================================================
# Editor / OS junk
# ==============================================================================
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.pem

# ==============================================================================
# Logs
# ==============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ==============================================================================
# Vercel
# ==============================================================================
.vercel

# ==============================================================================
# CATATAN: backend/models/ (file .pkl .npz .npy .json) SENGAJA TIDAK di-ignore
# supaya tim bisa langsung menjalankan backend setelah clone.
# ==============================================================================
